<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Usage access (last-used time & foreground usage time). This is an
        "app ops" special permission the user must grant in Settings, not a
        runtime dialog. StorageStatsManager for per-app size also relies on it.
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions"
        xmlns:tools="http://schemas.android.com/tools" />

    <!--
        Needed on Android 11+ (API 30) to enumerate every installed package.
        Without it, PackageManager only returns a filtered view. This is a
        sensitive permission and requires a Play Store declaration if published;
        appropriate for a device-management / app-manager tool.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        xmlns:tools="http://schemas.android.com/tools"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Lets the queue launch the system uninstall confirmation per app. -->
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppManager">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AppManager">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
