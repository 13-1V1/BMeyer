<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground: a blocky anvil (Forge) with a pixel spark (Sprite).
    Art is kept inside the central safe circle (radius ~32 around 54,54) so no
    launcher mask clips it. Sharp corners intentionally echo the pixel theme.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Anvil body (dark steel): top slab + horn, waist, base. -->
    <path
        android:fillColor="#20262C"
        android:pathData="M30,42h48v10h-48z M46,52h16v12h-16z M36,64h36v10h-36z M30,44l-5,3.5l5,3.5z" />

    <!-- Top-face highlight strip for a hint of depth. -->
    <path
        android:fillColor="#39434D"
        android:pathData="M30,42h48v3h-48z" />

    <!-- Pixel spark (gold): center block plus four offset pixels. -->
    <path
        android:fillColor="#FFD24A"
        android:pathData="M65,35h6v6h-6z M66,28h4v4h-4z M73,36h4v4h-4z M67,44h3v3h-3z M59,37h3v3h-3z" />

    <!-- Bright white core pixel. -->
    <path
        android:fillColor="#FFF6D5"
        android:pathData="M67,37h2v2h-2z" />
</vector>
